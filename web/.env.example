# CDC Web Dashboard Configuration

# Title of the dashboard application (optional)
VITE_APP_TITLE="CDC Data Pipeline Dashboard"

# The API base endpoint for the dashboard when accessed from the client browser
VITE_API_BASE_URL=http://localhost:8080/api/v1

# The internal/server-side API endpoint used for server-side rendering (SSR) context
# When running inside Docker / Kubernetes, this points directly to the api service name.
VITE_INTERNAL_API_BASE_URL=http://api:8080/api/v1
