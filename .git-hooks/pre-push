#!/usr/bin/env bash
set -eo pipefail

export PYTHONUNBUFFERED=1

# --- Working Directory Isolation ---
# Stash everything NOT being pushed so tests run on exactly what will ship.
HAS_STASHED=false
OLD_STASH=$(git rev-parse --verify refs/stash 2>/dev/null || true)
git stash push -k -u -q -m "pre-push stash"
NEW_STASH=$(git rev-parse --verify refs/stash 2>/dev/null || true)
if [ "$OLD_STASH" != "$NEW_STASH" ]; then
    HAS_STASHED=true
fi

API_PID=""
finish() {
    if [ -n "$API_PID" ]; then
        kill "$API_PID" 2>/dev/null || true
    fi
    if [ "$HAS_STASHED" = "true" ]; then
        git stash pop -q 2>/dev/null || true
    fi
    rm -f api.log
}
trap finish EXIT

# --- Escape Hatch ---
# If the commit being pushed contains [E2E NOT CHECKED] in its subject line,
# skip the slow container rebuild + E2E run (but still enforce fast unit tests).
ESCAPE=false
while read -r ref oid; do
    if [ "$ref" = "refs/heads/$(git symbolic-ref --short HEAD 2>/dev/null)" ]; then
        SUBJECT=$(git log -1 --format=%s "$oid")
        if echo "$SUBJECT" | grep -qi "\[E2E NOT CHECKED\]"; then
            ESCAPE=true
        fi
    fi
done

echo "========================================="
echo "   Pre-Push Local CI Gate"
echo "========================================="

# --- Fast Unit Tests (always run) ---
echo ""
echo "Running Go unit tests..."
go test -short -v $(go list ./internal/... | grep -v /test/e2e)
if [ $? -ne 0 ]; then
    echo ""
    echo "FAILED: Go unit tests. Push blocked."
    exit 1
fi

if [ -d "web" ] && [ -f "web/package.json" ]; then
    echo ""
    echo "Running frontend unit tests..."
    (cd web && pnpm run test)
    if [ $? -ne 0 ]; then
        echo ""
        echo "FAILED: Frontend unit tests. Push blocked."
        exit 1
    fi
fi

if [ "$ESCAPE" = "true" ]; then
    echo ""
    echo "WARNING: [E2E NOT CHECKED] in commit subject - skipping container build + E2E."
    echo "Fast tests passed. Push allowed (E2E bypassed)."
    exit 0
fi

# --- Container Rebuild ---
echo ""
echo "Checking for container runtime..."
CONTAINER_RUNTIME=""
if command -v podman &> /dev/null; then
    CONTAINER_RUNTIME="podman"
elif command -v docker &> /dev/null; then
    CONTAINER_RUNTIME="docker"
else
    echo "Neither podman nor docker found. Skipping image build."
    CONTAINER_RUNTIME=""
fi

if [ -n "$CONTAINER_RUNTIME" ]; then
    echo "Building cdc-pipeline-api..."
    $CONTAINER_RUNTIME build --ssh=default -t cdc-pipeline-api:latest -f Dockerfile .
    echo "Building cdc-pipeline-web-dashboard..."
    $CONTAINER_RUNTIME build -t cdc-pipeline-web-dashboard:latest -f web/Dockerfile web/
fi

# --- E2E Tests ---
echo ""
echo "Starting infrastructure (NATS + Postgres)..."
make e2e-up 2>&1

echo "Waiting for NATS (port 4222)..."
for i in {1..30}; do
    if (echo > /dev/tcp/127.0.0.1/4222) >/dev/null 2>&1; then
        echo "NATS is ready."
        break
    fi
    sleep 0.5
done

echo "Waiting for Postgres (port 5432)..."
for i in {1..30}; do
    if (echo > /dev/tcp/127.0.0.1/5432) >/dev/null 2>&1; then
        echo "Postgres is ready."
        break
    fi
    sleep 0.5
done

echo "Starting API server..."
JWT_SECRET="my-super-secret-jwt-key!" ENCRYPTION_KEY="my-super-secret-key-32-chars-long!" NATS_URL="nats://localhost:4222" go run ./cmd/api/main.go > api.log 2>&1 &
API_PID=$!

echo "Waiting for API server to be healthy..."
API_READY=false
for i in {1..30}; do
    if curl -s http://localhost:8080/healthz | grep -q "OK"; then
        API_READY=true
        break
    fi
    sleep 0.5
done

if [ "$API_READY" = "false" ]; then
    echo "FAILED: API server failed to start. Logs:"
    cat api.log
    exit 1
fi
echo "API server is ready."

echo ""
echo "Running E2E tests..."
TEST_STATUS=0
make e2e 2>&1 || TEST_STATUS=$?

echo ""
echo "Tearing down E2E infrastructure..."
make e2e-down 2>&1

if [ $TEST_STATUS -ne 0 ]; then
    echo ""
    echo "FAILED: E2E tests. Push blocked."
    echo "API server logs:"
    cat api.log
    exit 1
fi

echo ""
echo "All checks passed. Push allowed."
echo "========================================="
