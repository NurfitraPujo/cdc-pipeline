# CDC Pipeline Worker Configuration

# Service environment (production / development / test)
ENV=development

# Health check & metrics server port
HEALTH_PORT=8081

# Logging verbosity (debug, info, warn, error)
LOG_LEVEL=debug

# NATS JetStream connectivity url
NATS_URL=nats://localhost:4222

# Worker Group classification for task assignments
WORKER_GROUP=local

# Security & Encryption keys (must match API server to decrypt source/sink credentials)
ENCRYPTION_KEY=my-super-secret-key-32-chars-long!

# ==============================================================================
# Runtime Configuration & Connection Overrides
# Use these variables to dynamically configure database connections at startup.
# ==============================================================================

# PostgreSQL Source Database Settings
POSTGRES_SOURCE_HOST=localhost
POSTGRES_SOURCE_PORT=5432
POSTGRES_SOURCE_USER=postgres
POSTGRES_SOURCE_PASSWORD=postgres
POSTGRES_SOURCE_DB=production_db

# Databend Analytical Database Sink Settings
# Option A: Provide host and port (default port is 8000)
DATABEND_HOST=localhost
DATABEND_PORT=8000
# Option B: Direct connection DSN (overrides DATABEND_HOST/PORT if set)
# DATABEND_DSN=http://root:@localhost:8000

# PostgreSQL Debug Sink Settings
# Option A: Provide host, port, user, password, and database details
POSTGRES_DEBUG_HOST=localhost
POSTGRES_DEBUG_PORT=5433
POSTGRES_DEBUG_USER=postgres
POSTGRES_DEBUG_PASSWORD=postgres
POSTGRES_DEBUG_DB=debug_db
# Option B: Direct connection DSN (overrides POSTGRES_DEBUG_* variables if set)
# POSTGRES_DEBUG_DSN=postgres://postgres:postgres@localhost:5433/debug_db?sslmode=disable
