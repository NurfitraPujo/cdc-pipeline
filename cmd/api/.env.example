# CDC Control Plane API Configuration

# Service environment (production / development / test)
ENV=development

# Server port to listen on
PORT=8080

# Logging verbosity (debug, info, warn, error)
LOG_LEVEL=debug

# NATS JetStream connectivity url
NATS_URL=nats://localhost:4222

# Security & Encryption keys
# IMPORTANT: Provide a unique 32-character key in production
ENCRYPTION_KEY=my-super-secret-key-32-chars-long!
JWT_SECRET=my-super-secret-jwt-key!
